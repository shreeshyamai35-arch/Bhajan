# =====================================================================
# BhajanForge — Environment Variables
# Copy to ".env" at repo root and fill in. NEVER commit the real .env.
#
# DESIGN: fully cloud/serverless. NO local GPU required. All heavy audio AI
# (music, voice conversion, stem separation, mastering) runs via cloud APIs.
# The pipeline itself runs on any CPU machine / laptop.
# Final output is SAVED LOCALLY (no auto-upload to YouTube).
# =====================================================================

# ---------------------------------------------------------------------
# LLM PROVIDER (Orchestrator + agents). Choose one provider and set keys.
# ---------------------------------------------------------------------
LLM_PROVIDER=                 # e.g. openai | anthropic | azure
LLM_MODEL=                    # a frontier reasoning model id
LLM_API_KEY=
LLM_API_BASE=                 # optional, for proxy
LLM_FAST_MODEL=               # optional cheaper model for simple subtasks

# ---------------------------------------------------------------------
# EMBEDDINGS (RAG) — multilingual, must handle Hindi/Devanagari (cloud)
# ---------------------------------------------------------------------
EMBEDDING_PROVIDER=           # provider name (cloud)
EMBEDDING_MODEL=              # e.g. a multilingual embedding model (bge-m3 class)
EMBEDDING_API_KEY=

# ---------------------------------------------------------------------
# MUSIC: SUNO — API-FIRST (recommended). No official Suno API exists, so this
# points at a Suno-compatible third-party gateway. Browser fallback is OFF by
# default (set SUNO_USE_BROWSER=true only if you have no API endpoint).
# ---------------------------------------------------------------------
SUNO_API_BASE=                # third-party Suno-compatible gateway base URL
SUNO_API_KEY=
SUNO_MODEL=suno-v5.5
SUNO_POLL_INTERVAL_SEC=5
SUNO_MAX_WAIT_SEC=600
SUNO_USE_BROWSER=false        # true => drive Suno web UI via browser-agent
SUNO_WEB_EMAIL=               # only used if SUNO_USE_BROWSER=true
SUNO_WEB_PASSWORD=

# ---------------------------------------------------------------------
# VOICE CONVERSION — pick a backend via VOICE_PROVIDER:
#   replicate    : Replicate cloud (serverless GPU, pay-per-run)  [most reliable]
#   colab_tunnel : FREE NVIDIA T4 via a Google Colab notebook exposed as an API
#                  (Gradio/FastAPI + ngrok/cloudflared tunnel). Set RVC_TUNNEL_URL.
#   kaggle_tunnel: FREE GPU via a Kaggle notebook (~30 GPU hrs/week) exposed the
#                  same way. Set RVC_TUNNEL_URL to the Kaggle tunnel.
#   kits         : Kits.AI API
# NOTE on free tiers: Colab/Kaggle are interactive notebooks, not always-on
# servers. The tunnel URL changes each session and may disconnect/idle out, so
# free backends are great for low cost but less reliable for unattended runs.
# The rvc-mcp interface is identical regardless of backend.
# ---------------------------------------------------------------------
VOICE_PROVIDER=replicate      # replicate | colab_tunnel | kaggle_tunnel | kits
REPLICATE_API_TOKEN=
REPLICATE_RVC_TRAIN_MODEL=replicate/train-rvc-model
REPLICATE_RVC_INFER_MODEL=zsxkib/realistic-voice-cloning
RVC_TUNNEL_URL=               # for colab_tunnel / kaggle_tunnel (e.g. https://xxxx.ngrok.app)
RVC_TUNNEL_TOKEN=             # optional shared secret to protect the tunnel
RVC_MODELS_DIR=./models/rvc   # stores trained model refs/metadata
RVC_DEFAULT_F0_METHOD=rmvpe

# Optional alternative voice provider
KITS_API_KEY=
KITS_VOICE_ID=

# Optional SVS path (ACE Studio via browser-agent) — disabled by default
ACE_ENABLED=false
ACE_STUDIO_EMAIL=
ACE_STUDIO_PASSWORD=

# ---------------------------------------------------------------------
# STEM SEPARATION — pick a backend via STEM_PROVIDER:
#   lalal        : LALAL.AI cloud API                              [most reliable]
#   replicate    : Replicate Demucs (serverless GPU)
#   colab_tunnel : FREE GPU via Colab notebook (UVR/Demucs) behind a tunnel
#   kaggle_tunnel: FREE GPU via Kaggle notebook behind a tunnel
# Used mainly to prep voice-training data from existing YouTube songs, and to
# clean guide vocals if needed. (Suno's own stem extraction is preferred in-pipeline.)
# ---------------------------------------------------------------------
STEM_PROVIDER=lalal           # lalal | replicate | colab_tunnel | kaggle_tunnel
LALAL_API_KEY=
REPLICATE_DEMUCS_MODEL=cjwbw/demucs
STEM_TUNNEL_URL=              # for colab_tunnel / kaggle_tunnel
STEM_TUNNEL_TOKEN=

# ---------------------------------------------------------------------
# ASR (pronunciation check + lyric bootstrap) — cloud, multilingual (Hindi)
# ---------------------------------------------------------------------
ASR_PROVIDER=                 # cloud ASR provider
ASR_MODEL=                    # multilingual model id
ASR_API_KEY=

# ---------------------------------------------------------------------
# MASTERING — LANDR API PRIMARY (cloud, label-grade). matchering = free fallback.
# ---------------------------------------------------------------------
MASTERING_PROVIDER=landr      # landr | matchering
LANDR_API_KEY=
LANDR_MASTER_INTENSITY=medium # low | medium | high

# ---------------------------------------------------------------------
# RAG — Qdrant (run locally via docker-compose, CPU only)
# ---------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=bhajan_kb

# ---------------------------------------------------------------------
# OUTPUT — SAVE LOCALLY (no YouTube upload). Packager writes here.
# ---------------------------------------------------------------------
OUTPUT_DIR=./output           # final master + artwork + metadata land here
MAKE_VIDEO=false              # true => also render a static-art/lyric video locally

# ---------------------------------------------------------------------
# PUBLISHING — DISABLED by default. Final audio is saved to OUTPUT_DIR only.
# (Kept optional for future manual use; AI-disclosure stays required if ever on.)
# ---------------------------------------------------------------------
PUBLISH_TARGET=local          # local | youtube   (default: local — do NOT upload)
YOUTUBE_CLIENT_SECRETS=
YOUTUBE_TOKEN_STORE=
YOUTUBE_DEFAULT_PRIVACY=private

# ---------------------------------------------------------------------
# MEDIA DOWNLOAD (fetch existing bhajans for KB + voice training)
# ---------------------------------------------------------------------
# yt-dlp is used directly; no key needed.

# ---------------------------------------------------------------------
# RUNTIME / GOVERNANCE (defaults mirror config/rules.md)
# ---------------------------------------------------------------------
PUBLISH_MODE=draft            # draft | auto   (kept for review gating)
QUALITY_GATE=95
MAX_LOOP_ATTEMPTS=4
MAX_TOTAL_LOOPS=8
MUSIC_CANDIDATES=2
RUNS_DIR=./runs

# ---------------------------------------------------------------------
# OBSERVABILITY (optional)
# ---------------------------------------------------------------------
LANGSMITH_API_KEY=
LOG_LEVEL=INFO
